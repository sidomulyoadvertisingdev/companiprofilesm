# Copy this file to .env and fill in your values.
# .env is gitignored; never commit real secrets.

# Database (required)
DB_HOST=localhost
DB_PORT=3306
DB_USER=sidomulyo
DB_PASSWORD=Advertising@01
DB_NAME=sidomulyo_profile

# AI Customer Service Chat (required for the chat widget to answer)
# Provider: "openai" (default) or "gemini"
AI_PROVIDER=openai
# OpenAI: https://platform.openai.com/api-keys
# Gemini: https://aistudio.google.com/app/apikey
AI_API_KEY=
# Optional model override
# OpenAI default: gpt-4o-mini  |  Gemini default: gemini-1.5-flash
AI_MODEL=
# Optional custom OpenAI-compatible base URL (for Azure / local LLMs)
# AI_BASE_URL=https://api.openai.com/v1

# Email SMTP (required for marketplace email verification)
# Gmail: use App Password, not regular password
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# Cloudflare Turnstile (required for bot protection)
# Get keys at https://dash.cloudflare.com/turnstile
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
