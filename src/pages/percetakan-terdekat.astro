---
import MainLayout from "../layouts/MainLayout.astro";
import NearbyPrinter from "../components/NearbyPrinter.jsx";
---

<MainLayout
  title="Percetakan Terdekat | Sidomulyo Advertising Salatiga - Cari Percetakan di Dekat Saya"
  description="Cari percetakan terdekat? Sidomulyo Advertising di Jl. Kartini No.108, Salatiga adalah percetakan terdekat untuk Anda. Cek jarak dengan fitur geolocation, hubungi sekarang!"
>
  <main class="pt-20">
    <section class="min-h-[70vh] flex items-center bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h1 class="text-5xl md:text-6xl font-semibold text-[#1d1d1f] mb-6">
          Percetakan Terdekat
        </h1>
        <p class="text-xl text-[#6e6e73] max-w-3xl leading-relaxed">
          Cari <strong>percetakan terdekat</strong> dari lokasi Anda? Sidomulyo Advertising di Jl. Kartini No.108, Salatiga siap melayani kebutuhan percetakan dan advertising Anda. Gunakan fitur di bawah untuk mengecek jarak dari lokasi Anda!
        </p>
        <a
          href="https://wa.me/6288808888880"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex items-center rounded-full bg-[#1d1d1f] text-white px-8 py-4 text-sm font-medium hover:bg-black transition"
        >
          Hubungi via WhatsApp
        </a>
      </div>
    </section>

    <NearbyPrinter client:load />
  </main>
</MainLayout>
