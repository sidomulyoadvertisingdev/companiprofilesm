---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Percetakan di Semarang | Sidomulyo Advertising - Cepat Jadi & Profesional"
  description="Butuh percetakan di Semarang? Sidomulyo Advertising melayani pengiriman ke Semarang untuk neon box, banner, digital printing, huruf timbul. Kualitas terbaik, harga kompetitif, cepat jadi."
>
  <main class="pt-20">
    <section class="min-h-[70vh] flex items-center bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h1 class="text-5xl md:text-6xl font-semibold text-[#1d1d1f] mb-6">
          Percetakan di Semarang
        </h1>
        <p class="text-xl text-[#6e6e73] max-w-3xl leading-relaxed">
          Sidomulyo Advertising melayani kebutuhan <strong>percetakan di Semarang</strong> dengan pengiriman cepat dan hasil berkualitas. Kami menyediakan neon box, digital printing, huruf timbul, dan branding profesional untuk bisnis Anda di Semarang dan sekitarnya.
        </p>
        <a
          href="https://wa.me/6288808888880"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex items-center rounded-full bg-[#1d1d1f] text-white px-8 py-4 text-sm font-medium hover:bg-black transition"
        >
          Konsultasi via WhatsApp
        </a>
      </div>
    </section>

    <section class="py-24 bg-[#f5f5f7]">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-4xl font-semibold mb-12 text-center">Layanan Percetakan Semarang</h2>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-white rounded-3xl p-8">
            <h3 class="text-xl font-medium mb-3">Neon Box</h3>
            <p class="text-[#6e6e73]">Neon box akrilik dan LED untuk branding toko di Semarang. Desain modern, tahan lama.</p>
          </div>
          <div class="bg-white rounded-3xl p-8">
            <h3 class="text-xl font-medium mb-3">Digital Printing</h3>
            <p class="text-[#6e6e73]">Cetak banner, spanduk, poster berkualitas tinggi. Siap kirim ke Semarang.</p>
          </div>
          <div class="bg-white rounded-3xl p-8">
            <h3 class="text-xl font-medium mb-3">Huruf Timbul</h3>
            <p class="text-[#6e6e73]">Huruf timbul akrilik, stainless, galvanis untuk tampilan profesional.</p>
          </div>
          <div class="bg-white rounded-3xl p-8">
            <h3 class="text-xl font-medium mb-3">Branding</h3>
            <p class="text-[#6e6e73]">Solusi branding lengkap untuk bisnis di Semarang dan Jawa Tengah.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white text-center">
      <h2 class="text-4xl font-semibold mb-6">Butuh Percetakan di Semarang?</h2>
      <p class="text-lg text-[#6e6e73] mb-8 max-w-3xl mx-auto">Kami melayani pengiriman ke seluruh Semarang. Hubungi kami untuk konsultasi gratis!</p>
      <a href="https://wa.me/6288808888880" target="_blank" rel="noopener noreferrer" class="inline-flex items-center rounded-full bg-[#1d1d1f] text-white px-10 py-4 text-sm font-medium hover:bg-black transition">
        Hubungi via WhatsApp
      </a>
    </section>
  </main>
</MainLayout>
