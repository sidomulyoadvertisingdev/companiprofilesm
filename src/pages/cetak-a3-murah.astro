---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Cetak A3 Murah | Sidomulyo Advertising - Percetakan A3 Salatiga"
  description="Cetak A3 murah di Salatiga. Sidomulyo Advertising melayani cetak A3 hitam putih dan warna, kertas HVS dan art paper. Cepat jadi, hasil berkualitas, harga termurah. Cocok untuk makalah, poster, dokumen."
>
  <main class="pt-20">
    <section class="min-h-[70vh] flex items-center bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h1 class="text-5xl md:text-6xl font-semibold text-[#1d1d1f] mb-6">
          Cetak A3 Murah
        </h1>
        <p class="text-xl text-[#6e6e73] max-w-3xl leading-relaxed">
          Cari <strong>cetak A3 murah</strong> dan berkualitas di Salatiga? Sidomulyo Advertising melayani cetak ukuran A3 hitam putih maupun full color dengan hasil tajam dan rapi. Cocok untuk makalah, poster, laporan, dokumen, dan berbagai keperluan cetak lainnya.
        </p>
        <a
          href="https://wa.me/6288808888880"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex items-center rounded-full bg-[#1d1d1f] text-white px-8 py-4 text-sm font-medium hover:bg-black transition"
        >
          Pesan Cetak A3 via WhatsApp
        </a>
      </div>
    </section>

    <section class="py-24 bg-[#f5f5f7]">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-4xl font-semibold mb-12 text-center">Layanan Cetak A3</h2>
        <div class="grid md:grid-cols-3 gap-12">
          <div class="bg-white rounded-3xl p-8">
            <h3 class="text-xl font-medium mb-3">Cetak A3 Hitam Putih</h3>
            <p class="text-[#6e6e73]">Cetak A3 monokrom untuk dokumen, makalah, dan laporan. Harga ekonomis, hasil jelas dan rapi.</p>
          </div>
          <div class="bg-white rounded-3xl p-8">
            <h3 class="text-xl font-medium mb-3">Cetak A3 Full Color</h3>
            <p class="text-[#6e6e73]">Cetak A3 warna untuk poster, brosur, presentasi, dan materi promosi. Hasil tajam dengan warna akurat.</p>
          </div>
          <div class="bg-white rounded-3xl p-8">
            <h3 class="text-xl font-medium mb-3">Cetak A3 Kertas Khusus</h3>
            <p class="text-[#6e6e73]">Tersedia kertas HVS, art paper, kalkir, dan stiker ukuran A3 untuk berbagai kebutuhan.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-4xl font-semibold mb-8 text-center">Harga Cetak A3 Murah</h2>
        <div class="max-w-lg mx-auto bg-[#f5f5f7] rounded-3xl p-8 text-center">
          <p class="text-[#6e6e73] mb-4">Untuk informasi harga cetak A3 terbaru dan penawaran khusus, hubungi kami langsung via WhatsApp.</p>
          <p class="text-lg font-medium text-[#1d1d1f]">Dapatkan harga spesial untuk cetak dalam jumlah banyak!</p>
        </div>
      </div>
    </section>

    <section class="py-24 bg-[#f5f5f7] text-center">
      <h2 class="text-4xl font-semibold mb-6">Pesan Cetak A3 Sekarang</h2>
      <p class="text-lg text-[#6e6e73] mb-8 max-w-3xl mx-auto">Butuh cetak A3 murah dan cepat? Hubungi Sidomulyo Advertising sekarang!</p>
      <a href="https://wa.me/6288808888880" target="_blank" rel="noopener noreferrer" class="inline-flex items-center rounded-full bg-[#1d1d1f] text-white px-10 py-4 text-sm font-medium hover:bg-black transition">
        Hubungi via WhatsApp
      </a>
    </section>
  </main>
</MainLayout>
