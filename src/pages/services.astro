---
import MainLayout from "../layouts/MainLayout.astro";
import { FiArrowRight } from "react-icons/fi";
import { services } from "../data/services.js";
import { site } from "../data/site.js";
---

<MainLayout
  title="Layanan Percetakan & Advertising - Sidomulyo Advertising Salatiga"
  description="Layanan percetakan dan advertising profesional: neon box, digital printing, huruf timbul, branding. Cepat jadi, mesin tercanggih, hasil berkualitas. Melayani Salatiga, Semarang, dan sekitarnya."
>
  <main class="pt-20">
    <section class="min-h-[55vh] flex items-center bg-white dark:bg-[#0a0a1a] transition-colors">
      <div class="max-w-6xl mx-auto px-6">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 dark:text-white">
          Layanan Kami
        </h1>
        <p class="text-xl text-[#6e6e73] dark:text-slate-400 max-w-3xl">
          Kami menyediakan berbagai layanan percetakan dan advertising untuk
          mendukung branding serta promosi bisnis Anda — cepat jadi dengan
          mesin tercanggih.
        </p>
      </div>
    </section>

    <section class="py-24 bg-[#f5f5f7] dark:bg-[#111118] transition-colors">
      <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-10">
        {services.map((item) => (
          <div class="bg-white dark:bg-slate-800 rounded-3xl p-10 shadow-sm transition-colors">
            <h3 class="text-2xl font-semibold mb-4 dark:text-white">{item.title}</h3>
            <p class="text-[#6e6e73] dark:text-slate-400 text-lg leading-relaxed mb-6">{item.longDesc}</p>
            <ul class="space-y-2">
              {item.features.map((f) => (
                <li class="flex items-start gap-2 text-[#1d1d1f] dark:text-slate-200">
                  <span class="mt-1 w-1.5 h-1.5 rounded-full bg-blue-700 shrink-0"></span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="py-24 bg-white dark:bg-[#0a0a1a] text-center transition-colors">
      <h2 class="text-4xl font-bold mb-12 dark:text-white">Proses Kerja Kami</h2>
      <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-4 gap-10">
        {["Konsultasi Kebutuhan", "Desain & Perencanaan", "Produksi", "Pemasangan & Finishing"].map((step, i) => (
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-blue-50 dark:bg-blue-950/50 text-blue-700 flex items-center justify-center font-bold mb-4">
              {i + 1}
            </div>
            <p class="text-lg font-medium text-[#1d1d1f] dark:text-slate-200">{step}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="py-24 bg-[#f5f5f7] dark:bg-[#111118] text-center transition-colors">
      <h2 class="text-4xl font-bold mb-6 dark:text-white">
        Siap Meningkatkan Branding Bisnis Anda?
      </h2>
      <a
        href={`https://wa.me/${site.phone}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2
               rounded-full bg-blue-700 text-white
               px-10 py-4 text-sm font-semibold
               hover:bg-blue-400 transition"
      >
        Konsultasi Sekarang via WhatsApp
        <FiArrowRight />
      </a>
    </section>
  </main>
</MainLayout>
