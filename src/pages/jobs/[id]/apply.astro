---
import MainLayout from "../../../layouts/MainLayout.astro";
import ApplyJob from "../../../react-pages/ApplyJob.jsx";

export function getStaticPaths() {
  return [{ params: { id: "1" } }];
}

const { id } = Astro.params;
---

<MainLayout
  title="Lamar Pekerjaan - Sidomulyo Advertising"
  description="Kirim lamaran pekerjaan untuk posisi di Sidomulyo Advertising. Isi formulir dan lampirkan CV Anda."
>
  <ApplyJob id={id} client:load />
</MainLayout>
