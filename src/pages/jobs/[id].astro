---
import MainLayout from "../../layouts/MainLayout.astro";
import JobDetail from "../../react-pages/JobDetail.jsx";

export const prerender = true;

export function getStaticPaths() {
  return [{ params: { id: "1" } }];
}

const { id } = Astro.params;
---

<MainLayout
  title="Detail Lowongan Kerja - Sidomulyo Advertising"
  description="Lihat detail lowongan pekerjaan di Sidomulyo Advertising. Lamar sekarang dan bergabung dengan tim kami."
>
  <JobDetail id={id} client:load />
</MainLayout>
