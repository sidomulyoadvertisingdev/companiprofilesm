---
import "../styles/index.css";
import GlobeShowcase from "../components/ui/GlobeShowcase.jsx";
import MarketplaceForm from "../components/MarketplaceForm.jsx";
import { site } from "../data/site.js";
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Marketplace - Sidomulyo Advertising</title>
    <meta name="description" content="Marketplace Sidomulyo Advertising — segera hadir. Belanja produk percetakan dan advertising secara online." />
    <link rel="icon" href="/favicon.ico" />
    <script is:inline>
      (function () {
        var t = localStorage.getItem("theme");
        if (t === "dark" || (!t && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="bg-[#0a0a1a] text-slate-200">
    <main class="min-h-screen flex items-center justify-center relative overflow-hidden">
      <div class="absolute inset-0 z-0">
        <GlobeShowcase client:only="react" />
      </div>

      <div class="relative z-10 text-center px-6">
        <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm px-4 py-1.5 mb-8">
          <span class="w-2 h-2 rounded-full bg-blue-700 animate-pulse"></span>
          <span class="text-xs font-medium text-slate-300 tracking-wide uppercase">Coming Soon</span>
        </div>

        <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight">
          Marketplace
        </h1>

        <p class="text-lg md:text-xl text-slate-400 max-w-xl mx-auto mb-10 leading-relaxed">
          Platform belanja online untuk produk percetakan dan advertising.
          Pesan banner, neon box, huruf timbul, dan lainnya dalam satu tempat.
        </p>

        <MarketplaceForm client:only="react" />

        <div class="flex items-center justify-center gap-4 mt-10">
          <a href="https://web.facebook.com/profile.php?id=61579035969507" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm flex items-center justify-center text-slate-400 hover:text-white hover:border-white/30 transition" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href={site.social.find(s => s.label === "Instagram")?.href || "#"} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm flex items-center justify-center text-slate-400 hover:text-white hover:border-white/30 transition" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <a href={site.social.find(s => s.label === "WhatsApp")?.href || "#"} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm flex items-center justify-center text-slate-400 hover:text-white hover:border-white/30 transition" aria-label="WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </a>
        </div>
      </div>
    </main>
  </body>
</html>
