---
import MainLayout from "../layouts/MainLayout.astro";
import { getSite, getStats } from "../lib/queries.js";
import { FiArrowRight } from "react-icons/fi";

const s = await getSite();
const stats = await getStats();
---

<MainLayout
  title="Tentang Sidomulyo Advertising - Percetakan Profesional di Salatiga"
  description="Kenali Sidomulyo Advertising & Printing, perusahaan percetakan dan advertising profesional di Salatiga. Berpengalaman dengan mesin tercanggih untuk neon box, banner, digital printing, dan branding."
>
  <main class="pt-20">
    <section class="min-h-[55vh] flex items-center bg-white dark:bg-[#0a0a1a] transition-colors">
      <div class="max-w-6xl mx-auto px-6">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 dark:text-white">
          Tentang Sidomulyo Advertising
        </h1>
        <p class="text-xl text-[#6e6e73] dark:text-slate-400 max-w-3xl leading-relaxed">
          Kami adalah perusahaan percetakan dan advertising profesional yang
          berpusat di <strong class="dark:text-slate-200">{s.address.city}, {s.address.region}</strong> —
          didukung mesin tercanggih dan tim ahli untuk hasil terbaik.
        </p>
      </div>
    </section>

    <section class="py-24 bg-[#f5f5f7] dark:bg-[#111118] transition-colors">
      <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-4xl font-bold mb-6 dark:text-white">Siapa Kami</h2>
          <p class="text-[#6e6e73] dark:text-slate-400 text-lg leading-relaxed">
            {s.name} adalah perusahaan digital printing dan advertising yang
            berlokasi di <strong class="dark:text-slate-200">{s.address.street}, {s.address.city}</strong>.
            Kami melayani berbagai kebutuhan promosi dan branding untuk bisnis di
            {s.serviceArea.join(", ")} dengan mesin tercanggih dan hasil cepat jadi.
          </p>
        </div>
        <div class="flex justify-center">
          <div class="bg-white dark:bg-slate-800 rounded-3xl shadow-sm p-10 transition-colors">
            <img
              src={s.logo}
              alt={s.name}
              class="h-40 md:h-48 w-auto object-contain mx-auto"
              width="500"
              height="200"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white dark:bg-[#0a0a1a] transition-colors">
      <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-16">
        <div>
          <h3 class="text-3xl font-bold mb-4 dark:text-white">Visi</h3>
          <p class="text-[#6e6e73] dark:text-slate-400 text-lg">
            Menjadi perusahaan percetakan dan advertising terpercaya dengan
            kualitas terbaik di Indonesia — dimulai dari Salatiga untuk seluruh
            nusantara.
          </p>
        </div>
        <div>
          <h3 class="text-3xl font-bold mb-4 dark:text-white">Misi</h3>
          <ul class="text-[#6e6e73] dark:text-slate-400 text-lg space-y-3 list-disc list-inside">
            <li>Memberikan hasil cetak berkualitas tinggi dengan mesin modern</li>
            <li>Mengutamakan kepuasan pelanggan dengan layanan cepat jadi</li>
            <li>Mengikuti perkembangan teknologi percetakan terbaru</li>
            <li>Pelayanan cepat, profesional, dan tepat waktu</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="py-24 bg-[#f5f5f7] dark:bg-[#111118] transition-colors">
      <div class="max-w-6xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-10 text-center">
        {stats.map((s) => (
          <div>
            <div class="text-4xl md:text-5xl font-bold text-blue-700">
              {s.value}{s.suffix}
            </div>
            <div class="mt-2 text-sm text-[#6e6e73] dark:text-slate-400">{s.label}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="py-24 bg-white dark:bg-[#0a0a1a] text-center transition-colors">
      <h2 class="text-4xl font-bold mb-6 dark:text-white">Siap Bekerja Sama dengan Kami?</h2>
      <p class="text-lg text-[#6e6e73] dark:text-slate-400 mb-8 max-w-3xl mx-auto">
        Butuh percetakan cepat jadi di {s.address.city}? Hubungi kami sekarang!
      </p>
      <a
        href={`https://wa.me/${s.phone}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-full bg-blue-700 text-white px-8 py-4 text-sm font-semibold hover:bg-blue-400 transition"
      >
        Hubungi Kami via WhatsApp
        <FiArrowRight />
      </a>
    </section>
  </main>
</MainLayout>
