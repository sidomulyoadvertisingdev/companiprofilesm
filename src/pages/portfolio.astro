---
import MainLayout from "../layouts/MainLayout.astro";
import { getPortfolio, getSite } from "../lib/queries.js";
import PortfolioPage from "../react-pages/PortfolioPage.jsx";

const portfolio = await getPortfolio();
const site = await getSite();
---

<MainLayout
  title="Portofolio - Sidomulyo Advertising | Percetakan Profesional Salatiga"
  description="Lihat portofolio proyek percetakan dan advertising Sidomulyo Advertising: neon box, banner, huruf timbul, branding untuk berbagai klien di Salatiga dan sekitarnya."
>
  <PortfolioPage client:load initialData={portfolio} siteData={site} />
</MainLayout>
