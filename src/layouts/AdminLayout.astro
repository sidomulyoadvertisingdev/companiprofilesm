---
import "../styles/index.css";

const {
  title = "Admin - Sidomulyo Advertising CMS",
  description = "Panel admin CMS Sidomulyo Advertising.",
} = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/webp" href="/logo-sidomulyo.webp" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="bg-[#f5f5f7] text-[#1d1d1f]">
    <slot />
  </body>
</html>
